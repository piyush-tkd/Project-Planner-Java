meta {
  name: Save Credentials
  type: http
  seq: 13
}

post {
  url: {{base_url}}/api/jira/credentials
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
  {
    "baseUrl": "https://yourcompany.atlassian.net",
    "email": "your-email@company.com",
    "apiToken": "your-api-token"
  }
}
